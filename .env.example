# --- Database Configuration ---
# Desarrollo local SIN Docker: comenta DATABASE_URL para usar SQLite (./trading.db).
# Desarrollo CON docker compose: usa el host de servicio "db" (no localhost).
POSTGRES_USER=trading_user
POSTGRES_PASSWORD=trading_pass
POSTGRES_DB=trading_db
DATABASE_URL=postgresql://trading_user:trading_pass@db/trading_db

# --- Caching Configuration ---
REDIS_URL=redis://redis:6379/0

# --- API Configuration ---
API_HOST=0.0.0.0
API_PORT=8000
DEBUG=True

# --- Exchange API Keys (Placeholders) ---
# BINANCE_API_KEY=
# BINANCE_API_SECRET=
# ALPACA_API_KEY=
# ALPACA_API_SECRET=

# --- OpenAI / Anthropic / Local LLM ---
# OLLAMA_HOST=http://host.docker.internal:11434

# --- Paper Trading Configuration ---
PAPER_TRADING_ENABLED=True
PAPER_TRADING_INITIAL_BALANCE=10000
PAPER_TRADING_FEE_RATE=0.001

# --- Adaptive Orchestrator (Auto Trading Control) ---
AUTO_ORCHESTRATOR_ENABLED=false
AUTO_ORCHESTRATOR_INTERVAL_SEC=180
AUTO_ORCHESTRATOR_SYMBOL=BTC/USDT
AUTO_ORCHESTRATOR_ALLOCATION=350
AUTO_ORCHESTRATOR_MAX_ACTIVE=3
AUTO_ORCHESTRATOR_WINDOW_TRADES=30
