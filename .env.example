# --- Database Configuration ---
# Desarrollo local SIN Docker: comenta DATABASE_URL para usar SQLite (./trading.db).
# Desarrollo CON docker compose: usa el host de servicio "db" (no localhost).
POSTGRES_USER=trading_user
POSTGRES_PASSWORD=trading_pass
POSTGRES_DB=trading_db
DATABASE_URL=postgresql://trading_user:trading_pass@db/trading_db

# --- Caching Configuration ---
REDIS_URL=redis://redis:6379/0

# --- API Configuration ---
API_HOST=0.0.0.0
API_PORT=8000
DEBUG=True

# --- Seguridad de acceso (recomendado en producción) ---
# Activa login obligatorio para entrar al dashboard/API.
# APP_AUTH_ENABLED=true
# APP_AUTH_USERNAME=admin
# APP_AUTH_PASSWORD_HASH=pbkdf2_sha256:...   # Genera con: python scripts/generate_app_auth_hash.py
# APP_AUTH_SECRET_KEY=CAMBIA_ESTA_CLAVE_LARGA_ALEATORIA
# APP_AUTH_SESSION_MINUTES=720
# APP_AUTH_IDLE_TIMEOUT_MINUTES=30
# APP_AUTH_MAX_FAILED_ATTEMPTS=5
# APP_AUTH_LOCKOUT_MINUTES=15
# APP_AUTH_TOTP_ENABLED=true
# APP_AUTH_TOTP_SECRET=BASE32SECRET
# APP_AUTH_COOKIE_SECURE=true         # true si usas HTTPS

# --- Backups automáticos de BD cifrados ---
# Genera clave Fernet: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# DB_BACKUP_ENABLED=true
# DB_BACKUP_ENCRYPTION_KEY=
# DB_BACKUP_INTERVAL_SEC=3600
# DB_BACKUP_RETENTION_DAYS=14
# DB_BACKUP_DIR=backups/db

# --- Exchange API Keys (Placeholders) ---
# BINANCE_API_KEY=
# BINANCE_API_SECRET=
# ALPACA_API_KEY=
# ALPACA_API_SECRET=

# --- OpenAI / Anthropic / Local LLM ---
# OLLAMA_HOST=http://host.docker.internal:11434

# --- Paper Trading Configuration ---
PAPER_TRADING_ENABLED=True
PAPER_TRADING_INITIAL_BALANCE=10000
PAPER_TRADING_FEE_RATE=0.001

# --- Hyperliquid (operaciones reales / testnet) ---
# HYPERLIQUID_WALLET_ADDRESS=0x...                    # tu wallet en Hyperliquid
# HYPERLIQUID_SIGNING_KEY=0x...                      # API wallet / agente; alternativa: guardar solo cifrado en BD (ver abajo)
# HYPERLIQUID_USE_TESTNET=true                       # false solo para mainnet (fondos reales)
# HYPERLIQUID_USE_ENCRYPTED_CREDENTIALS=false        # true si la signing key va solo en tabla encrypted_credentials
#
# Cifrado en backend (opcional): la signing key se guarda cifrada en la BD; la clave maestra SOLO en este archivo / entorno.
# Generar: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# APP_CREDENTIALS_FERNET_KEY=
#
# Opcional: si defines SECRETS_ADMIN_TOKEN, POST /api/settings/hyperliquid/save exige header X-Secrets-Admin-Token
# SECRETS_ADMIN_TOKEN=

# --- Adaptive Orchestrator (Auto Trading Control) ---
AUTO_ORCHESTRATOR_ENABLED=false
AUTO_ORCHESTRATOR_INTERVAL_SEC=180
AUTO_ORCHESTRATOR_SYMBOL=BTC/USDT
AUTO_ORCHESTRATOR_SYMBOLS=BTC/USDT,ETH/USDT,ADA/USDT
AUTO_ORCHESTRATOR_ALLOCATION=350
AUTO_ORCHESTRATOR_MAX_ACTIVE=3
AUTO_ORCHESTRATOR_WINDOW_TRADES=30
# AUTO_ORCHESTRATOR_AUTOLAUNCH_MAINNET=false
# AUTO_ORCHESTRATOR_MAINNET_MIN_CONFIDENCE=90
# AUTO_ORCHESTRATOR_MAINNET_ALLOWED_HORIZONS=medio,largo

# Si está en true, un bot marcado con analysis_approved/candidate_for_production/production_ready
# puede entrar al flujo de auto-promoción aunque no haya completado la muestra mínima tradicional.
# PRODUCTION_ALLOW_FLAG_OVERRIDE=false
# PRODUCTION_GUARD_ENABLED=true
# PRODUCTION_GUARD_INTERVAL_SEC=60
# PRODUCTION_KILL_SWITCH_ENABLED=true
# PRODUCTION_KILL_DAILY_LOSS_ABS=25
# PRODUCTION_KILL_FAILED_ORDERS_THRESHOLD=6
# PRODUCTION_KILL_FAILED_ORDERS_WINDOW_MIN=20
# AUTONOMY_WATCHDOG_ENABLED=true
# AUTONOMY_WATCHDOG_INTERVAL_SEC=60
# AUTONOMY_WATCHDOG_SYNC_POSITIONS=true
# AUTONOMY_WATCHDOG_REASSIGN_POSITIONS=true
# LIVE_EXECUTION_GUARD_ENABLED=true
# LIVE_MIN_TRADE_INTERVAL_SEC=45
# LIVE_MIN_REENTRY_MOVE_PCT=0.001
# LIVE_MIN_CLOSE_PROFIT_PCT=0.0012
# LIVE_FORCE_CLOSE_LOSS_PCT=0.0035
# HYPERLIQUID_TAKER_FEE_PCT=0.00045
# EMA_MIN_SPREAD_PCT=0.0005
# EMA_MIN_SLOPE_PCT=0.0002
